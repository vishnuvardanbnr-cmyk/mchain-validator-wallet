{
  "expo": {
    "name": "MChain Validator Wallet",
    "slug": "mchain-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mchain-wallet",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan QR codes to get recipient addresses",
        "UIBackgroundModes": ["fetch", "processing"]
      }
    },
    "android": {
      "permissions": ["CAMERA", "RECEIVE_BOOT_COMPLETED"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MChain Wallet to scan QR codes for recipient addresses."
        }
      ],
      "expo-secure-store",
      "expo-task-manager",
      "expo-background-fetch"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
